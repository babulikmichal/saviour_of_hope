    cout << endl << endl << endl << endl << "--------------------------------" << endl << "Kdysi byval svet plny svetla. Lide ovladali magii, rodili se se schopnostmi, ktere dokazaly menit beh dejin. Byli strazci rovnovahy, ochranci risi, posledni hrazi proti temnote. Ale kdyz se otevrel brany Pekelne rise, jejich sila nestacila.";
    cout << endl << "Osmnactileta valka spalila vse" << endl << "Hrdinove padli, mesta se zmenila v ruiny, magie se vycerpala. Demonicti pani si rozdelili svet jako korist a jejich armady hlidaji kazdy kout zeme." << endl; 
    cont();
    cout << "A pak prislo to nejhorsi — ticho." << endl << "Ne boj, ne odpor. Jen ticho tech, kteri uz nemaji silu zvednout hlavu." << endl << "Lide se schovavaji v troskach, v jeskynich, v podzemnich tunelech. Neveri v navrat svetla. Vetsina z nich uz prijala, ze svet patri demonum. Ze nadeje byla jen pohadka pro deti. Ze hrdinove jsou mrtvi a magie je jen ozvena minulosti." << endl;
    cout << endl << "Ale ty… ty jsi jiny." << endl << endl << "Ne proto, ze bys byl silnejsi. Ne proto, ze bys mel moc zmenit svet. Ale proto, ze ses odmitl vzdat. Protoze v tobe zustalo neco, co ostatni ztratili — presvedceni, ze i v popelu muze prezit jiskra." << endl << endl << "--------------------------------" << endl << endl;
    cont();

    cout << "Probudil jsi se s pocitem, jako by ti nekdo rozdrtil lebku kamenem." << endl << "Kocovina. Zase..." << endl << "V tomhle svete je to jedina vec, ktera jeste dokaze cloveka na chvili odtrhnout od reality." << endl << "Od toho, co z ni zustalo." << endl << endl;
    cout << "Zvedl jsi se z provizorniho luzka, ktere vrzalo jako stara kost. Vzduch v ukrytu byl tezky, zatuchly, plny dychu lidi, kteri uz davno prestali zit a jen prezivaji." << endl << "Nekteri se smali. Takovy ten smich, co zni spis jako priznani porazky." << endl <<"Jini jen sedeli a koukali do zdi." << endl << "A ty... ty jsi se snazil vzpomenout, kolik jsi toho vlastne vypil. A proc." << endl;
    cont();
    cout << "Tenhle zivot te znechucoval. " << "„K cemu je zivot kdyz ho ani nemuzes zit,“ pomyslel sis." << endl;
    cout << "Vyrazil jsi mezi ostatni a prezivci a zacal jsi se ptat na otazky jako, co se deje venku, jestli se nekdo jeste pokousi bojovat." << endl;
    cout << "Odpovedi byly vzdycky stejne." << endl << "Kroutili hlavou. Rikali ti, ze venku neni nic, jen demoni, prach a smrt. Ze tady je to jedine misto, kde se da prezit. Ze nadeje je jen slovo, ktere uz nema zadny vyznam." << endl;
    cont();
    cout << "Tvoje otazky ale neuplne zapadly. Velitel ukrytu si te zavolal." << endl << "Sedel za starou deskou stolu, popraskanou a poskrabanou, jako by prezila vic bitev nez on sam. Kdyz jsi vstoupil, ani se na tebe nepodival." << endl;
    cout << "„Ty chces odejit,“ pronesl klidne." << endl << "Chvili mlcel, jako by hledal slova, ktera uz davno ztratila silu." << endl;
    cont();
    cout << "„Nedelej to. Venku neni nic, co by stalo za to. Tady mas aspon sanci. Tam venku... tam venku jsi jen dalsi mrtvola, ktera jeste nevi, ze je mrtva.“" << endl << "Neodpovedel jsi. Nemusel jsi." << endl << "Videla to na tobe kazda vraska v jeho tvari." << endl;
    cout << "Nakonec jen prikyvl. Pomalu, smutne, ale bez odporu." << endl;
    cont();
    cout << "Zvedl se a zasel do sve komory." << endl << " Ty jsi se taky zvedl a chstal jsi se odejit, kdyz vturanu se ozval krikot at pockas. Byl to velitel ukrytu nesouci ";
