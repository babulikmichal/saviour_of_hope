void lcrit() {
srand(time(0));
nacrit = rand() % 101 + 0;
if (nacrit == 100 || ncrit == 1) {
    dmg = atk * 1.5 * dm;
} else {
    dmg = atk * dm;
}
}

void crit() {
srand(time(0));
ncrit = rand() % 101 + 0;
if (ncrit == 100 || ncrit == 1) {
    dmg = atk * 1.5 * dm * 0.4;
} else {
    dmg = atk * dm;
}
}
void nahod() {
